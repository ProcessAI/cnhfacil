# Conexão com o banco PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:SENHA@localhost:5432/cnhfacil"

# Porta em que o servidor Express vai escutar
PORT=3000

# Chave secreta para assinar os tokens JWT
# Use uma string longa e aleatória em produção (ex: openssl rand -base64 48)
JWT_SECRET="troque_por_uma_chave_longa_e_aleatoria"

# Ambiente de execução: development | production
NODE_ENV=development
